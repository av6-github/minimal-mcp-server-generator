{
  "name": "gemini-rocketchat-mcp-generator",
  "version": "1.0.0",
  "description": "A gemini-cli extension that generates minimal MCP servers for Rocket.Chat",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "copy-specs": "cp -r src/specs dist/specs",
    "dev": "ts-node --esm src/server.ts"
  },
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-yaml": "^4.1.0",
    "vitest": "^4.1.0",
    "wink-bm25-text-search": "^3.1.2",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "@types/swagger-parser": "^4.0.3",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
